<div class="space-y-8">
  <!-- Page Header -->
  <div class="text-center mb-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
      <%= config.title %>
    </h1>
    <% if (config.subtitle) { %>
    <p class="text-lg text-gray-600 dark:text-gray-400">
      <%= config.subtitle %>
    </p>
    <% } %>
  </div>

  <!-- Article List -->
  <div class="space-y-6">
    <% page.posts.each(function(post) { %>
    <article class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-md transition-shadow">
      <div class="p-6">
        <!-- Title -->
        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-3">
          <a href="<%= url_for(post.path) %>" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            <%= post.title %>
          </a>
        </h2>

        <!-- Meta -->
        <div class="flex flex-wrap items-center text-sm text-gray-500 dark:text-gray-400 mb-4 space-x-4">
          <time datetime="<%= date_xml(post.date) %>">
            <%= date(post.date, 'YYYY-MM-DD') %>
          </time>
          
          <% if (post.categories && post.categories.length) { %>
          <span class="flex items-center">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
            </svg>
            <% post.categories.each(function(category) { %>
            <a href="<%= url_for(category.path) %>" class="hover:text-blue-600 dark:hover:text-blue-400">
              <%= category.name %>
            </a>
            <% }); %>
          </span>
          <% } %>

          <% if (theme.article && theme.article.readtime) { %>
          <span class="flex items-center">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <%= strip_html(post.content).length / 400 %> 分钟
          </span>
          <% } %>
        </div>

        <!-- Excerpt -->
        <div class="text-gray-600 dark:text-gray-400 mb-4">
          <% if (post.excerpt) { %>
            <%= strip_html(post.excerpt) %>
          <% } else { %>
            <%= strip_html(post.content).substring(0, 200) %>...
          <% } %>
        </div>

        <!-- Tags -->
        <% if (post.tags && post.tags.length) { %>
        <div class="flex flex-wrap gap-2">
          <% post.tags.each(function(tag) { %>
          <a href="<%= url_for(tag.path) %>" 
             class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900 hover:text-blue-700 dark:hover:text-blue-300 transition-colors">
            <%= tag.name %>
          </a>
          <% }); %>
        </div>
        <% } %>
      </div>

      <!-- Read More -->
      <div class="px-6 py-4 bg-gray-50 dark:bg-gray-900/50 border-t border-gray-200 dark:border-gray-700">
        <a href="<%= url_for(post.path) %>" 
           class="inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-medium transition-colors">
          阅读全文
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </article>
    <% }); %>
  </div>

  <!-- Pagination -->
  <% if (page.total > 1) { %>
  <nav class="flex items-center justify-between mt-12">
    <% if (page.prev) { %>
    <a href="<%= url_for(page.prev_link) %>" 
       class="inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      上一页
    </a>
    <% } else { %>
    <span></span>
    <% } %>

    <span class="text-sm text-gray-500 dark:text-gray-400">
      <%= page.current %> / <%= page.total %>
    </span>

    <% if (page.next) { %>
    <a href="<%= url_for(page.next_link) %>" 
       class="inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
      下一页
      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
    <% } else { %>
    <span></span>
    <% } %>
  </nav>
  <% } %>
</div>