<div class="space-y-10">
  <!-- Hero Section - 重新设计的大标题区域 -->
  <section class="hero-section relative overflow-hidden rounded-3xl bg-gradient-to-br from-blue-50 via-white to-purple-50 dark:from-zinc-900 dark:via-zinc-900 dark:to-zinc-800 border border-zinc-200/50 dark:border-zinc-800/50 py-16 sm:py-20 px-6 sm:px-8 text-center mb-12">
    <!-- 装饰性背景元素 -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute top-10 left-10 w-32 h-32 bg-blue-500/10 dark:bg-blue-500/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-40 h-40 bg-purple-500/10 dark:bg-purple-500/5 rounded-full blur-3xl"></div>
    </div>
    
    <!-- 主标题区域 -->
    <div class="relative z-10">
      <!-- Logo 图标 -->
      <div class="inline-flex items-center justify-center w-20 h-20 sm:w-24 sm:h-24 rounded-2xl bg-gradient-to-br from-blue-500 via-blue-600 to-purple-600 shadow-xl shadow-blue-500/25 dark:shadow-blue-500/10 mb-8 transform hover:scale-105 transition-transform duration-300">
        <svg class="w-10 h-10 sm:w-12 sm:h-12 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
      </div>
      
      <!-- 站点标题 -->
      <h1 class="hero-title text-4xl sm:text-5xl lg:text-6xl font-bold font-heading mb-4 bg-gradient-to-r from-zinc-900 via-zinc-800 to-zinc-900 dark:from-white dark:via-zinc-200 dark:to-white bg-clip-text text-transparent">
        <%= config.title %>
      </h1>
      
      <!-- 副标题 -->
      <% if (config.subtitle) { %>
      <p class="hero-subtitle text-lg sm:text-xl text-zinc-500 dark:text-zinc-400 max-w-2xl mx-auto leading-relaxed">
        <%= config.subtitle %>
      </p>
      <% } %>
      
      <!-- 装饰线 -->
      <div class="mt-8 flex items-center justify-center gap-3">
        <div class="h-px w-12 bg-gradient-to-r from-transparent to-zinc-300 dark:to-zinc-700"></div>
        <div class="w-2 h-2 rounded-full bg-blue-500/50"></div>
        <div class="h-px w-12 bg-gradient-to-l from-transparent to-zinc-300 dark:to-zinc-700"></div>
      </div>
    </div>
  </section>

  <!-- Article List -->
  <div class="space-y-8">
    <% page.posts.each(function(post) { %>
    <article class="group bg-bg-secondary rounded-2xl border border-border-custom overflow-hidden hover:shadow-xl hover:shadow-zinc-200/50 dark:hover:shadow-black/30 transition-all duration-300 hover:-translate-y-1">
      <div class="p-6 sm:p-8">
        <!-- Title -->
        <h2 class="font-heading text-2xl sm:text-3xl font-bold mb-4">
          <a href="<%= url_for(post.path) %>" class="bg-gradient-to-r from-zinc-900 to-zinc-700 dark:from-white dark:to-zinc-300 bg-clip-text text-transparent group-hover:from-blue-600 group-hover:to-blue-400 dark:group-hover:from-blue-400 dark:group-hover:to-blue-300 transition-all">
            <%= post.title %>
          </a>
        </h2>

        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-text-secondary mb-5">
          <time datetime="<%= date_xml(post.date) %>" class="flex items-center">
            <svg class="w-4 h-4 mr-1.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <%= date(post.date, 'YYYY年MM月DD日') %>
          </time>

          <% if (post.categories && post.categories.length) { %>
          <span class="flex items-center">
            <svg class="w-4 h-4 mr-1.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
            </svg>
            <% post.categories.each(function(category) { %>
            <a href="<%= url_for(category.path) %>" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
              <%= category.name %>
            </a>
            <% }); %>
          </span>
          <% } %>

          <% if (theme.article && theme.article.readtime) { %>
          <span class="flex items-center">
            <svg class="w-4 h-4 mr-1.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <%= Math.ceil(strip_html(post.content).length / 400) %> 分钟阅读
          </span>
          <% } %>
        </div>

        <!-- Excerpt -->
        <div class="text-text-secondary leading-relaxed mb-6 line-clamp-3">
          <% if (post.excerpt) { %>
            <%= strip_html(post.excerpt) %>
          <% } else { %>
            <%= strip_html(post.content).substring(0, 180) %>...
          <% } %>
        </div>

        <!-- Tags -->
        <% if (post.tags && post.tags.length) { %>
        <div class="flex flex-wrap gap-2 mb-6">
          <% post.tags.each(function(tag) { %>
          <a href="<%= url_for(tag.path) %>"
             class="tag-link inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:text-blue-700 dark:hover:text-blue-300 transition-all">
            <%= tag.name %>
          </a>
          <% }); %>
        </div>
        <% } %>

        <!-- Read More -->
        <a href="<%= url_for(post.path) %>"
           class="inline-flex items-center text-sm font-semibold text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors group/link">
          阅读全文
          <svg class="w-4 h-4 ml-1.5 transform group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </article>
    <% }); %>
  </div>

  <!-- Pagination -->
  <% if (page.total > 1) { %>
  <nav class="flex items-center justify-center gap-4 mt-12">
    <% if (page.prev) { %>
    <a href="<%= url_for(page.prev_link) %>"
       class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-zinc-700 dark:text-zinc-300 bg-bg-secondary border border-border-custom hover:border-blue-500/50 dark:hover:border-blue-400/50 hover:shadow-lg hover:shadow-blue-500/10 dark:hover:shadow-blue-400/10 transition-all">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      上一页
    </a>
    <% } else { %>
    <span class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-zinc-400 dark:text-zinc-600 bg-bg-secondary/50 border border-border-custom/50 cursor-not-allowed">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      上一页
    </span>
    <% } %>

    <span class="px-4 py-2 text-sm font-medium text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800/50 rounded-lg">
      <%= page.current %> / <%= page.total %>
    </span>

    <% if (page.next) { %>
    <a href="<%= url_for(page.next_link) %>"
       class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-zinc-700 dark:text-zinc-300 bg-bg-secondary border border-border-custom hover:border-blue-500/50 dark:hover:border-blue-400/50 hover:shadow-lg hover:shadow-blue-500/10 dark:hover:shadow-blue-400/10 transition-all">
      下一页
      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
    <% } else { %>
    <span class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-zinc-400 dark:text-zinc-600 bg-bg-secondary/50 border border-border-custom/50 cursor-not-allowed">
      下一页
      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </span>
    <% } %>
  </nav>
  <% } %>
</div>
