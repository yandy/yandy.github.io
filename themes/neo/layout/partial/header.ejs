<!-- 顶部遮挡条，防止内容滚动时透出 -->
<div class="fixed top-0 left-0 right-0 h-4 bg-bg-primary z-50"></div>

<header class="fixed top-4 left-4 right-4 z-50">
  <div class="max-w-5xl mx-auto">
    <nav class="bg-white/80 dark:bg-zinc-900/80 backdrop-blur-xl rounded-2xl border border-zinc-200/60 dark:border-zinc-800/60 shadow-lg shadow-zinc-200/20 dark:shadow-black/20 px-4 sm:px-6">
      <div class="flex items-center justify-between h-14">
        <!-- Logo -->
        <a href="<%= url_for('/') %>" class="flex items-center space-x-3 group">
          <% if (theme.logo) { %>
          <img src="<%= url_for(theme.logo) %>" alt="<%= config.title %>" class="h-8 w-8 rounded-lg ring-2 ring-zinc-200 dark:ring-zinc-700 group-hover:ring-blue-500 dark:group-hover:ring-blue-400 transition-all">
          <% } %>
          <span class="font-heading text-lg font-bold bg-gradient-to-r from-zinc-900 to-zinc-600 dark:from-white dark:to-zinc-400 bg-clip-text text-transparent group-hover:from-blue-600 group-hover:to-blue-400 dark:group-hover:from-blue-400 dark:group-hover:from-blue-300 transition-all">
            <%= config.title %>
          </span>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center space-x-1">
          <% if (theme.navbar && theme.navbar.menu) { %>
            <% for (var key in theme.navbar.menu) { %>
              <a href="<%= url_for(theme.navbar.menu[key]) %>" 
                 class="px-3 py-1.5 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-all">
                <%= key %>
              </a>
            <% } %>
          <% } %>
          
          <!-- Dark Mode Toggle -->
          <% if (theme.dark_mode && theme.dark_mode.toggle) { %>
          <button id="theme-toggle" 
                  class="ml-2 p-2 rounded-lg text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-all"
                  aria-label="Toggle dark mode">
            <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
          </button>
          <% } %>
        </div>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-toggle" class="md:hidden p-2 rounded-lg text-zinc-600 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Navigation -->
      <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-zinc-200/50 dark:border-zinc-800/50 mt-2">
        <nav class="flex flex-col space-y-1 pt-2">
          <% if (theme.navbar && theme.navbar.menu) { %>
            <% for (var key in theme.navbar.menu) { %>
              <a href="<%= url_for(theme.navbar.menu[key]) %>" 
                 class="px-3 py-2 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-all">
                <%= key %>
              </a>
            <% } %>
          <% } %>
          
          <!-- Mobile Dark Mode Toggle -->
          <% if (theme.dark_mode && theme.dark_mode.toggle) { %>
          <button id="theme-toggle-mobile" 
                  class="flex items-center px-3 py-2 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-all">
            <span class="mr-2">切换主题</span>
            <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
          </button>
          <% } %>
        </nav>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-24"></div>

<script>
  // Mobile menu toggle
  document.getElementById('mobile-menu-toggle')?.addEventListener('click', function() {
    const menu = document.getElementById('mobile-menu');
    menu?.classList.toggle('hidden');
  });
</script>