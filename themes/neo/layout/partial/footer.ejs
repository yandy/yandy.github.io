<footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-16">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Recent Posts -->
    <% if (theme.footer && theme.footer.show_recent_posts) { %>
    <div class="mb-8">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">最新文章</h3>
      <ul class="space-y-2">
        <% site.posts.sort('date', -1).limit(theme.footer.recent_posts_count || 5).each(function(post) { %>
        <li>
          <a href="<%= url_for(post.path) %>" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            <%= post.title %>
          </a>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-2">
            <%= date(post.date, 'YYYY-MM-DD') %>
          </span>
        </li>
        <% }); %>
      </ul>
    </div>
    <% } %>

    <!-- Footer Bottom -->
    <div class="flex flex-col sm:flex-row items-center justify-between pt-8 border-t border-gray-200 dark:border-gray-800">
      <div class="text-sm text-gray-500 dark:text-gray-400 mb-4 sm:mb-0">
        <% if (theme.footer && theme.footer.copyright) { %>
          <%= theme.footer.copyright %>
        <% } else { %>
          © <%= date(new Date(), 'YYYY') %> <%= config.author || config.title %>
        <% } %>
      </div>
      
      <div class="flex items-center space-x-4">
        <!-- RSS -->
        <% if (config.feed && config.feed.enable) { %>
        <a href="<%= url_for(config.feed.path) %>" 
           class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
           aria-label="RSS Feed">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.503 20.752c0 2.155-1.75 3.903-3.903 3.903s-3.903-1.748-3.903-3.903c0-2.154 1.748-3.902 3.903-3.902 2.153 0 3.903 1.748 3.903 3.902zm9.902-.003c0 2.154-1.748 3.902-3.903 3.902-1.168 0-2.217-.52-2.93-1.34-.713-.82-1.13-1.878-1.13-2.562 0-2.153 1.748-3.902 3.903-3.902s3.903 1.749 3.903 3.902h.157zm6.905-.003c0 2.154-1.748 3.902-3.903 3.902-1.168 0-2.217-.52-2.93-1.34-.713-.82-1.13-1.878-1.13-2.562 0-2.153 1.748-3.902 3.903-3.902s3.903 1.749 3.903 3.902z"/>
          </svg>
        </a>
        <% } %>
        
        <!-- GitHub -->
        <a href="https://github.com/yandy" 
           target="_blank" 
           rel="noopener noreferrer"
           class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
           aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>