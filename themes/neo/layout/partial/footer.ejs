<footer class="mt-20 border-t border-border-custom bg-bg-secondary/50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
      <!-- Brand -->
      <div>
        <a href="<%= url_for('/') %>" class="inline-flex items-center space-x-2 mb-4">
          <span class="font-heading text-xl font-bold bg-gradient-to-r from-zinc-900 to-zinc-600 dark:from-white dark:to-zinc-400 bg-clip-text text-transparent">
            <%= config.title %>
          </span>
        </a>
        <% if (config.description) { %>
        <p class="text-sm text-text-secondary leading-relaxed">
          <%= config.description %>
        </p>
        <% } %>
      </div>

      <!-- Recent Posts -->
      <% if (theme.footer && theme.footer.show_recent_posts) { %>
      <div>
        <h3 class="font-heading text-sm font-semibold text-text-primary mb-4 flex items-center">
          <svg class="w-4 h-4 mr-2 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
            <polyline points="10 9 9 9 8 9"></polyline>
          </svg>
          最新文章
        </h3>
        <ul class="space-y-2.5">
          <% site.posts.sort('date', -1).limit(theme.footer.recent_posts_count || 5).each(function(post) { %>
          <li>
            <a href="<%= url_for(post.path) %>" class="text-sm text-text-secondary hover:text-blue-600 dark:hover:text-blue-400 transition-colors line-clamp-1">
              <%= post.title %>
            </a>
          </li>
          <% }); %>
        </ul>
      </div>
      <% } %>

      <!-- Links -->
      <div>
        <h3 class="font-heading text-sm font-semibold text-text-primary mb-4 flex items-center">
          <svg class="w-4 h-4 mr-2 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
          </svg>
          链接
        </h3>
        <div class="flex items-center space-x-4">
          <!-- RSS -->
          <% if (config.feed && config.feed.enable) { %>
          <a href="<%= url_for(config.feed.path) %>"
             class="p-2.5 rounded-xl bg-zinc-100 dark:bg-zinc-800 text-zinc-500 hover:text-orange-500 hover:bg-orange-50 dark:hover:bg-orange-900/20 transition-all"
             aria-label="RSS Feed">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.503 20.752c0 2.155-1.75 3.903-3.903 3.903s-3.903-1.748-3.903-3.903c0-2.154 1.748-3.902 3.903-3.902 2.153 0 3.903 1.748 3.903 3.902zm9.902-.003c0 2.154-1.748 3.902-3.903 3.902-1.168 0-2.217-.52-2.93-1.34-.713-.82-1.13-1.878-1.13-2.562 0-2.153 1.748-3.902 3.903-3.902s3.903 1.749 3.903 3.902h.157zm6.905-.003c0 2.154-1.748 3.902-3.903 3.902-1.168 0-2.217-.52-2.93-1.34-.713-.82-1.13-1.878-1.13-2.562 0-2.153 1.748-3.902 3.903-3.902s3.903 1.749 3.903 3.902z"/>
            </svg>
          </a>
          <% } %>

          <!-- GitHub -->
          <a href="https://github.com/yandy"
             target="_blank"
             rel="noopener noreferrer"
             class="p-2.5 rounded-xl bg-zinc-100 dark:bg-zinc-800 text-zinc-500 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-all"
             aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="pt-8 border-t border-border-custom flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-sm text-text-tertiary">
        <% if (theme.footer && theme.footer.copyright) { %>
          <%= theme.footer.copyright %>
        <% } else { %>
          © <%= date(new Date(), 'YYYY') %> <%= config.author || config.title %>
        <% } %>
      </div>

      <div class="text-sm text-text-tertiary flex items-center">
        <span>使用</span>
        <svg class="w-4 h-4 mx-1.5 text-blue-500" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2L1 21h22L12 2zm0 3.5L19.5 19h-15L12 5.5z"/>
          <path d="M12 8l-4.5 8h9L12 8z" opacity="0.5"/>
        </svg>
        <span class="font-medium text-blue-500">Hexo</span>
        <span class="ml-1">构建</span>
      </div>
    </div>
  </div>
</footer>