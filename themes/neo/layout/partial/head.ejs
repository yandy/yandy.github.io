<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">

<%
var title = page.title;
  if (is_archive()) {
    title = '归档';
  } else if (is_category()) {
    title = '分类: ' + page.category;
  } else if (is_tag()) {
    title = '标签: ' + page.tag;
}
%>

<title><% if (title) { %><%= title %> | <% } %><%= config.title %></title>

<% if (page.description) { %>
<meta name="description" content="<%= page.description %>">
<% } else if (config.description) { %>
<meta name="description" content="<%= config.description %>">
<% } %>

<% if (page.keywords) { %>
<meta name="keywords" content="<%= page.keywords %>">
<% } else if (config.keywords) { %>
<meta name="keywords" content="<%= config.keywords %>">
<% } %>

<meta name="author" content="<%= config.author %>">

<!-- Open Graph -->
<meta property="og:type" content="<%= page.layout || 'website' %>">
<meta property="og:title" content="<%= title || config.title %>">
<meta property="og:url" content="<%= url %>">
<meta property="og:site_name" content="<%= config.title %>">
<% if (page.description) { %>
<meta property="og:description" content="<%= page.description %>">
<% } %>
<% if (page.thumbnail) { %>
<meta property="og:image" content="<%= page.thumbnail %>">
<% } %>

<!-- Twitter Card -->
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="<%= title || config.title %>">
<% if (page.description) { %>
<meta name="twitter:description" content="<%= page.description %>">
<% } %>

<!-- Favicon -->
<% if (theme.favicon) { %>
<link rel="icon" href="<%= url_for(theme.favicon) %>">
<% } %>

<!-- RSS -->
<% if (config.feed && config.feed.enable) { %>
<link rel="alternate" type="application/atom+xml" title="<%= config.title %>" href="<%= url_for(config.feed.path) %>">
<% } %>

<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = {
  darkMode: ['class', '[data-theme="dark"]'],
  theme: {
    extend: {
      colors: {
        primary: '#3b82f6',
        'primary-dark': '#60a5fa'
      },
      fontFamily: {
        sans: ['system-ui', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
        mono: ['ui-monospace', 'SFMono-Regular', 'SF Mono', 'Menlo', 'Consolas', 'Liberation Mono', 'monospace']
      }
    }
  }
}
</script>

<!-- Highlight.js Theme -->
<link rel="stylesheet" href="<%- url_for('/css/highlight-theme.css') %>">

<!-- Theme Styles -->
<link rel="stylesheet" href="<%- url_for('/css/style.css') %>">