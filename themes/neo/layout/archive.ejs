<div class="space-y-8">
  <!-- Page Header -->
  <div class="text-center mb-12">
    <div class="inline-flex items-center justify-center w-14 h-14 mb-5 rounded-2xl bg-gradient-to-br from-zinc-600 to-zinc-800 dark:from-zinc-500 dark:to-zinc-700 shadow-lg">
      <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <polyline points="10 9 9 9 8 9"></polyline>
      </svg>
    </div>
    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text-primary mb-4">
      文章归档
    </h1>
    <p class="text-text-secondary">
      共 <%= site.posts.length %> 篇文章
    </p>
  </div>

  <!-- Archive List -->
  <div class="space-y-8">
    <% var lastYear = 0; %>
    <% page.posts.each(function(post) { %>
      <% var year = post.date.year(); %>
      <% if (year !== lastYear) { %>
        <% if (lastYear !== 0) { %></div><% } %>
        <div class="space-y-4">
          <h2 class="font-heading text-2xl font-bold text-text-primary border-b border-border-custom pb-3 flex items-center">
            <svg class="w-6 h-6 mr-3 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <%= year %>
          </h2>
      <% } %>

      <article class="flex items-center space-x-4 py-3 group">
        <time class="flex items-center text-sm text-text-tertiary w-28 flex-shrink-0">
          <svg class="w-4 h-4 mr-2 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          <%= date(post.date, 'MM-DD') %>
        </time>
        <a href="<%= url_for(post.path) %>"
           class="flex items-center text-text-primary hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-colors">
          <svg class="w-4 h-4 mr-2 text-text-tertiary group-hover:text-blue-500 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
          </svg>
          <%= post.title %>
        </a>
      </article>

      <% lastYear = year; %>
    <% }); %>
    <% if (lastYear !== 0) { %></div><% } %>
  </div>

  <!-- Pagination -->
  <% if (page.total > 1) { %>
  <nav class="flex items-center justify-center gap-4 mt-12">
    <% if (page.prev) { %>
    <a href="<%= url_for(page.prev_link) %>"
       class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-zinc-700 dark:text-zinc-300 bg-bg-secondary border border-border-custom hover:border-blue-500/50 dark:hover:border-blue-400/50 hover:shadow-lg hover:shadow-blue-500/10 dark:hover:shadow-blue-400/10 transition-all">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      上一页
    </a>
    <% } else { %>
    <span class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-zinc-400 dark:text-zinc-600 bg-bg-secondary/50 border border-border-custom/50 cursor-not-allowed">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      上一页
    </span>
    <% } %>

    <span class="px-4 py-2 text-sm font-medium text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800/50 rounded-lg">
      <%= page.current %> / <%= page.total %>
    </span>

    <% if (page.next) { %>
    <a href="<%= url_for(page.next_link) %>"
       class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-zinc-700 dark:text-zinc-300 bg-bg-secondary border border-border-custom hover:border-blue-500/50 dark:hover:border-blue-400/50 hover:shadow-lg hover:shadow-blue-500/10 dark:hover:shadow-blue-400/10 transition-all">
      下一页
      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
    <% } else { %>
    <span class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-zinc-400 dark:text-zinc-600 bg-bg-secondary/50 border border-border-custom/50 cursor-not-allowed">
      下一页
      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </span>
    <% } %>
  </nav>
  <% } %>
</div>
