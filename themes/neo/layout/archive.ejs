<div class="space-y-8">
  <!-- Page Header -->
  <div class="text-center mb-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
      文章
    </h1>
    <p class="text-gray-600 dark:text-gray-400">
      共 <%= site.posts.length %> 篇文章
    </p>
  </div>

  <!-- Archive List -->
  <div class="space-y-8">
    <% var lastYear = 0; %>
    <% page.posts.each(function(post) { %>
      <% var year = post.date.year(); %>
      <% if (year !== lastYear) { %>
        <% if (lastYear !== 0) { %></div><% } %>
        <div class="space-y-4">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">
            <%= year %>
          </h2>
      <% } %>

      <article class="flex items-start space-x-4 py-3">
        <time class="text-sm text-gray-500 dark:text-gray-400 w-24 flex-shrink-0">
          <%= date(post.date, 'MM-DD') %>
        </time>
        <a href="<%= url_for(post.path) %>"
           class="text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-colors">
          <%= post.title %>
        </a>
      </article>

      <% lastYear = year; %>
    <% }); %>
    <% if (lastYear !== 0) { %></div><% } %>
  </div>

  <!-- Pagination -->
  <% if (page.total > 1) { %>
  <nav class="flex items-center justify-between mt-12">
    <% if (page.prev) { %>
    <a href="<%= url_for(page.prev_link) %>"
       class="inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      上一页
    </a>
    <% } else { %>
    <span></span>
    <% } %>

    <span class="text-sm text-gray-500 dark:text-gray-400">
      <%= page.current %> / <%= page.total %>
    </span>

    <% if (page.next) { %>
    <a href="<%= url_for(page.next_link) %>"
       class="inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
      下一页
      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
    <% } else { %>
    <span></span>
    <% } %>
  </nav>
  <% } %>
</div>
