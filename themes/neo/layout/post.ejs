<div class="flex gap-8">
  <!-- TOC Sidebar - Desktop only -->
  <% var tocContent = toc(page.content, {list_number: false, max_depth: 3}); %>
  <% if (tocContent) { %>
  <aside class="hidden xl:block w-64 flex-shrink-0">
    <div class="sticky top-28 toc-sidebar">
      <div class="bg-bg-secondary/80 backdrop-blur-xl rounded-2xl border border-border-custom p-5 shadow-lg shadow-zinc-200/20 dark:shadow-black/20">
        <h3 class="font-heading text-sm font-bold text-text-primary mb-4 flex items-center">
          <svg class="w-4 h-4 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
          </svg>
          目录
        </h3>
        <nav class="toc-nav overflow-y-auto max-h-[calc(100vh-16rem)] text-sm">
          <%- tocContent %>
        </nav>
      </div>
    </div>
  </aside>
  <% } %>

  <!-- Main Content -->
  <article class="flex-1 min-w-0">
    <div class="bg-bg-secondary rounded-2xl border border-border-custom overflow-hidden shadow-lg shadow-zinc-200/20 dark:shadow-black/20">
      <!-- Header -->
      <header class="p-6 sm:p-10 border-b border-border-custom bg-gradient-to-br from-zinc-50/50 to-transparent dark:from-zinc-800/30 dark:to-transparent">
        <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold bg-gradient-to-r from-zinc-900 to-zinc-700 dark:from-white dark:to-zinc-300 bg-clip-text text-transparent mb-6 tracking-tight leading-tight">
          <%= page.title %>
        </h1>

        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-text-secondary">
          <time datetime="<%= date_xml(page.date) %>" class="flex items-center">
            <svg class="w-4 h-4 mr-1.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <%= date(page.date, 'YYYY年MM月DD日') %>
          </time>

          <% if (page.categories && page.categories.length) { %>
          <span class="flex items-center">
            <svg class="w-4 h-4 mr-1.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
            </svg>
            <% page.categories.each(function(category) { %>
            <a href="<%= url_for(category.path) %>" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
              <%= category.name %>
            </a>
            <% }); %>
          </span>
          <% } %>

          <% if (theme.article && theme.article.readtime) { %>
          <span class="flex items-center">
            <svg class="w-4 h-4 mr-1.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <%= Math.ceil(strip_html(page.content).length / 400) %> 分钟阅读
          </span>
          <% } %>

          <% if (theme.article && theme.article.update_time && page.updated) { %>
          <span class="flex items-center">
            <svg class="w-4 h-4 mr-1.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            更新于 <%= date(page.updated, 'YYYY-MM-DD') %>
          </span>
          <% } %>
        </div>
      </header>

      <!-- Content Wrapper -->
      <div class="p-6 sm:p-10">

        <!-- Content -->
        <div class="prose prose-lg max-w-none">
          <%- page.content %>
        </div>

        <!-- Tags -->
        <% if (page.tags && page.tags.length) { %>
        <div class="mt-10 pt-8 border-t border-border-custom">
          <div class="flex flex-wrap items-center gap-3">
            <span class="text-sm font-medium text-text-secondary">标签：</span>
            <% page.tags.each(function(tag) { %>
            <a href="<%= url_for(tag.path) %>"
               class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:text-blue-700 dark:hover:text-blue-300 transition-all">
              <%= tag.name %>
            </a>
            <% }); %>
          </div>
        </div>
        <% } %>

        <!-- Donation -->
        <% if (theme.donation && theme.donation.enable) { %>
        <div class="mt-10 pt-8 border-t border-border-custom text-center">
          <div class="bg-gradient-to-br from-blue-50/50 to-purple-50/50 dark:from-blue-900/20 dark:to-purple-900/20 rounded-2xl p-8">
            <svg class="w-12 h-12 mx-auto mb-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
            <p class="text-text-secondary mb-5">如果这篇文章对您有帮助，欢迎打赏支持</p>
            <button data-donation-trigger
                    class="inline-flex items-center px-8 py-3.5 rounded-xl text-base font-semibold text-white bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-700 hover:to-blue-600 shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 transform hover:-translate-y-0.5 transition-all">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
              打赏支持
            </button>
          </div>
        </div>
        <% } %>

        <!-- Navigation -->
        <nav class="mt-10 pt-8 border-t border-border-custom">
          <div class="flex flex-col sm:flex-row justify-between gap-4">
            <% if (page.prev) { %>
            <a href="<%= url_for(page.prev.path) %>"
               class="group flex items-center p-4 rounded-xl bg-zinc-50 dark:bg-zinc-800/50 border border-border-custom hover:border-blue-500/30 dark:hover:border-blue-400/30 hover:shadow-lg hover:shadow-blue-500/10 transition-all">
              <svg class="w-5 h-5 mr-3 text-zinc-400 group-hover:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
              <div>
                <span class="text-xs text-text-tertiary block mb-0.5">上一篇</span>
                <div class="font-heading font-medium text-text-primary group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-1"><%= page.prev.title %></div>
              </div>
            </a>
            <% } else { %>
            <span></span>
            <% } %>

            <% if (page.next) { %>
            <a href="<%= url_for(page.next.path) %>"
               class="group flex items-center justify-end p-4 rounded-xl bg-zinc-50 dark:bg-zinc-800/50 border border-border-custom hover:border-blue-500/30 dark:hover:border-blue-400/30 hover:shadow-lg hover:shadow-blue-500/10 transition-all sm:text-right">
              <div>
                <span class="text-xs text-text-tertiary block mb-0.5">下一篇</span>
                <div class="font-heading font-medium text-text-primary group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-1"><%= page.next.title %></div>
              </div>
              <svg class="w-5 h-5 ml-3 text-zinc-400 group-hover:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
            <% } %>
          </div>
        </nav>
      </div>
  </article>
</div>
