<article class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
  <div class="p-6 sm:p-8">
    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        <%= page.title %>
      </h1>

      <!-- Meta -->
      <div class="flex flex-wrap items-center text-sm text-gray-500 dark:text-gray-400 space-x-4">
        <time datetime="<%= date_xml(page.date) %>">
          <%= date(page.date, 'YYYY-MM-DD') %>
        </time>

        <% if (page.categories && page.categories.length) { %>
        <span class="flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
          </svg>
          <% page.categories.each(function(category) { %>
          <a href="<%= url_for(category.path) %>" class="hover:text-blue-600 dark:hover:text-blue-400">
            <%= category.name %>
          </a>
          <% }); %>
        </span>
        <% } %>

        <% if (theme.article && theme.article.readtime) { %>
        <span class="flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <%= strip_html(page.content).length / 400 %> 分钟阅读
        </span>
        <% } %>

        <% if (theme.article && theme.article.update_time && page.updated) { %>
        <span class="flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
          更新于 <%= date(page.updated, 'YYYY-MM-DD') %>
        </span>
        <% } %>
      </div>
    </header>

    <!-- Content -->
    <div class="prose prose-lg max-w-none">
      <%- page.content %>
    </div>

    <!-- Tags -->
    <% if (page.tags && page.tags.length) { %>
    <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
      <div class="flex flex-wrap gap-2">
        <% page.tags.each(function(tag) { %>
        <a href="<%= url_for(tag.path) %>" 
           class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900 hover:text-blue-700 dark:hover:text-blue-300 transition-colors">
          #<%= tag.name %>
        </a>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Donation -->
    <% if (theme.donation && theme.donation.enable) { %>
    <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700 text-center">
      <p class="text-gray-600 dark:text-gray-400 mb-4">如果这篇文章对您有帮助，欢迎打赏支持</p>
      <button data-donation-trigger 
              class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
        </svg>
        打赏支持
      </button>
    </div>
    <% } %>

    <!-- Navigation -->
    <nav class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
      <div class="flex flex-col sm:flex-row justify-between gap-4">
        <% if (page.prev) { %>
        <a href="<%= url_for(page.prev.path) %>" 
           class="flex items-center text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          <div>
            <span class="text-xs text-gray-400 dark:text-gray-500">上一篇</span>
            <div class="font-medium"><%= page.prev.title %></div>
          </div>
        </a>
        <% } %>

        <% if (page.next) { %>
        <a href="<%= url_for(page.next.path) %>" 
           class="flex items-center justify-end text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
          <div class="text-right">
            <span class="text-xs text-gray-400 dark:text-gray-500">下一篇</span>
            <div class="font-medium"><%= page.next.title %></div>
          </div>
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
        <% } %>
      </div>
    </nav>
  </div>
</article>