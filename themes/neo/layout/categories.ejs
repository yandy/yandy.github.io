<% // 分类列表页面 - 展示所有分类 %>
<div class="categories-page">
  <div class="page-header">
    <h1 class="page-title">
      <svg class="icon-folder-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
      </svg>
      分类
    </h1>
    <span class="page-subtitle">
      共 <%= site.categories.length %> 个分类
    </span>
  </div>

  <div class="categories-list">
    <% site.categories.sort('name').each(function(category) { %>
      <div class="category-card">
        <a href="<%= url_for(category.path) %>" class="category-header">
          <div class="category-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <div class="category-info">
            <h3 class="category-name"><%= category.name %></h3>
            <span class="category-count">
              <%= category.posts.length %> 篇文章
            </span>
          </div>
          <div class="category-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
        </a>

        <% if (category.posts.length > 0) { %>
          <div class="category-posts-preview">
            <% category.posts.sort('-date').limit(3).each(function(post) { %>
              <a href="<%= url_for(post.path) %>" class="preview-post">
                <span class="preview-date">
                  <%= date(post.date, 'MM-DD') %>
                </span>
                <span class="preview-title" title="<%= post.title %>">
                  <%= post.title %>
                </span>
              </a>
            <% }); %>
            <% if (category.posts.length > 3) { %>
              <a href="<%= url_for(category.path) %>" class="preview-more">
                还有 <%= category.posts.length - 3 %> 篇
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    <% }); %>
  </div>
</div>

<style>
.categories-page {
  max-width: 900px;
  margin: 0 auto;
  padding: 20px;
}

.page-header {
  text-align: center;
  margin-bottom: 40px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border-color);
}

.page-title {
  font-family: var(--font-heading);
  font-size: 2rem;
  color: var(--text-primary);
  margin: 0 0 10px 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
}

.icon-folder-open {
  width: 32px;
  height: 32px;
  color: #f59e0b;
}

.page-subtitle {
  color: var(--text-tertiary);
  font-size: 0.95rem;
}

.categories-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.category-card {
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 16px;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.category-card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}

.category-header {
  display: flex;
  align-items: center;
  padding: 20px;
  text-decoration: none;
  color: inherit;
  gap: 15px;
}

.category-icon {
  width: 50px;
  height: 50px;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.category-icon svg {
  width: 24px;
  height: 24px;
  color: #fff;
}

.category-info {
  flex: 1;
  min-width: 0;
}

.category-name {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  font-weight: 600;
  color: var(--text-primary);
  margin: 0 0 5px 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.category-count {
  font-size: 0.85rem;
  color: var(--text-tertiary);
}

.category-arrow {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  transition: all 0.3s ease;
}

.category-arrow svg {
  width: 20px;
  height: 20px;
}

.category-card:hover .category-arrow {
  color: #f59e0b;
  transform: translateX(3px);
}

.category-posts-preview {
  border-top: 1px solid var(--border-color);
  padding: 15px 20px;
  background: var(--bg-tertiary);
}

.preview-post {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 0;
  text-decoration: none;
  color: var(--text-secondary);
  transition: all 0.2s ease;
  border-bottom: 1px dashed transparent;
}

.preview-post:last-of-type {
  border-bottom: none;
}

.preview-post:hover {
  color: #f59e0b;
}

.preview-date {
  font-size: 0.8rem;
  color: var(--text-tertiary);
  font-family: var(--font-mono, monospace);
  white-space: nowrap;
}

.preview-title {
  flex: 1;
  font-size: 0.9rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.preview-more {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 10px;
  padding: 6px 12px;
  font-size: 0.85rem;
  color: #f59e0b;
  text-decoration: none;
  background: var(--bg-secondary);
  border: 1px solid #f59e0b;
  border-radius: 15px;
  transition: all 0.3s ease;
}

.preview-more:hover {
  background: #f59e0b;
  color: #fff;
}

.preview-more svg {
  width: 14px;
  height: 14px;
}

/* 响应式 */
@media (max-width: 768px) {
  .categories-page {
    padding: 15px;
  }

  .page-title {
    font-size: 1.5rem;
  }

  .category-header {
    padding: 15px;
  }

  .category-icon {
    width: 40px;
    height: 40px;
  }

  .category-icon svg {
    width: 20px;
    height: 20px;
  }

  .category-name {
    font-size: 1rem;
  }

  .category-arrow {
    display: none;
  }

  .category-posts-preview {
    padding: 12px 15px;
  }

  .preview-title {
    font-size: 0.85rem;
  }
}
</style>
