<% // 标签列表页面 - 展示所有标签云 %>
<div class="tags-page">
  <div class="page-header">
    <h1 class="page-title">
      <svg class="icon-tags" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
        <line x1="7" y1="7" x2="7.01" y2="7"></line>
      </svg>
      标签
    </h1>
    <span class="page-subtitle">
      共 <%= site.tags.length %> 个标签
    </span>
  </div>

  <div class="tags-cloud">
    <% site.tags.sort('name').each(function(tag) { %>
      <a href="<%= url_for(tag.path) %>" class="tag-item" data-count="<%= tag.posts.length %>">
        <span class="tag-name">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
            <line x1="7" y1="7" x2="7.01" y2="7"></line>
          </svg>
          <%= tag.name %>
        </span>
        <span class="tag-count"><%= tag.posts.length %></span>
      </a>
    <% }); %>
  </div>
</div>

<style>
.tags-page {
  max-width: 900px;
  margin: 0 auto;
  padding: 20px;
}

.page-header {
  text-align: center;
  margin-bottom: 40px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border-color);
}

.page-title {
  font-family: var(--font-heading);
  font-size: 2rem;
  color: var(--text-primary);
  margin: 0 0 10px 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
}

.icon-tags {
  width: 32px;
  height: 32px;
  color: #3b82f6;
}

.page-subtitle {
  color: var(--text-tertiary);
  font-size: 0.95rem;
}

.tags-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
  padding: 20px 0;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 24px;
  text-decoration: none;
  color: var(--text-secondary);
  font-size: 0.9rem;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tag-item:hover {
  background: #3b82f6;
  border-color: #3b82f6;
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(59, 130, 246, 0.3);
}

.tag-item:hover .tag-count {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
}

.tag-name {
  display: flex;
  align-items: center;
  gap: 6px;
}

.tag-name svg {
  width: 14px;
  height: 14px;
  opacity: 0.8;
}

.tag-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 22px;
  height: 22px;
  padding: 0 6px;
  background: var(--bg-tertiary);
  border-radius: 11px;
  font-size: 0.75rem;
  color: var(--text-tertiary);
  font-weight: 500;
  transition: all 0.3s ease;
}

/* 响应式 */
@media (max-width: 768px) {
  .tags-page {
    padding: 15px;
  }

  .page-title {
    font-size: 1.5rem;
  }

  .tag-item {
    padding: 8px 14px;
    font-size: 0.85rem;
  }
}
</style>
